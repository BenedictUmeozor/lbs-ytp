# Convex development deployment identifier.
CONVEX_DEPLOYMENT=

# Public Convex deployment URL used by the React client.
NEXT_PUBLIC_CONVEX_URL=

# Clerk values used by the Next.js application. Do not commit real values.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard

# Configure these only in the Convex deployment environment. Never expose them
# through NEXT_PUBLIC_ variables or commit real values.
CLERK_JWT_ISSUER_DOMAIN=
DEMO_FLEET_MANAGER_EMAIL=
GEMINI_API_KEY=
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
